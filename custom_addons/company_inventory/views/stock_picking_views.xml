<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="stock_picking_form_company_inventory" model="ir.ui.view">
        <field name="name">stock.picking.form.company.inventory</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="x_dispatch_priority"/>
                <field name="x_processing_note"/>
            </xpath>
        </field>
    </record>
</odoo>
