<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="nine_tech_branding.NotificationAlert" t-inherit="web.NotificationAlert" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='isNotificationBlocked']" position="replace">
            <div t-if="isNotificationBlocked" class="alert alert-primary text-center">
                Browser push notifications are blocked. Go to your browser settings to allow notifications for 9tech ERP.
            </div>
        </xpath>
    </t>
</templates>
