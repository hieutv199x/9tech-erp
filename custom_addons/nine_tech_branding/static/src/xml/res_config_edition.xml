<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="nine_tech_branding.ResConfigEdition" t-inherit="res_config_edition" t-inherit-mode="extension">
        <xpath expr="//h3" position="replace">
            <h3 class="px-0">
                9tech ERP <t t-esc="serverVersion"/>
                (Community Edition)
            </h3>
        </xpath>
        <xpath expr="//small" position="replace">
            <small>
                Copyright © 9tech
                <a target="_blank" href="https://9tech.vn" style="text-decoration: underline;">9tech</a>
                <a id="license" target="_blank" href="http://www.gnu.org/licenses/lgpl.html" style="text-decoration: underline;">GNU LGPL Licensed</a>
            </small>
        </xpath>
    </t>
</templates>
